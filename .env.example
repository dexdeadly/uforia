# ─────────────────────────────────────────────────────────────────────────────
# Uforia — Environment Variables
# Copy this file to ".env" and fill in the values for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (required) ──────────────────────────────────────────────────────
# PostgreSQL connection string. Works with any standard Postgres instance.
# Example (local):  postgresql://uforia:uforia@localhost:5432/uforia
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?connect_timeout=15"

# ── File storage (optional) ──────────────────────────────────────────────────
# Uploaded files are stored on the local filesystem.
# Defaults to an "uploads/" directory at the project root.
# UPLOADS_DIR="/data/uforia/uploads"

# ── Answer generation / LLM (optional) ───────────────────────────────────────
# Uforia uses the Claude API (official Anthropic SDK) for answer generation.
# Get a key at https://platform.claude.com/
# If omitted, the app still works and returns extractive answers (top passages).
ANTHROPIC_API_KEY=""
# Chat model used for answer generation.
CHAT_MODEL="claude-opus-4-8"

# ── Embeddings (optional) ────────────────────────────────────────────────────
# Embeddings run LOCALLY via Transformers.js — no API key required.
# You can change the model; it must be a sentence-embedding model on the HF Hub.
EMBEDDING_MODEL="Xenova/all-MiniLM-L6-v2"
# Where downloaded model weights are cached (defaults to a temp dir).
# TRANSFORMERS_CACHE="/app/.cache/transformers"

# ── Site (optional) ──────────────────────────────────────────────────────────
# Public base URL, used for Open Graph / social image resolution.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
